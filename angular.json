{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "core": {
      "projectType": "library",
      "root": "projects/core",
      "sourceRoot": "projects/core/src",
      "prefix": "ngxfb",
      "schematics": {
        "@schematics/angular:component": {
          "inlineTemplate": false,
          "inlineStyle": true
        }
      },
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/core/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/core/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/core/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "browsers": [
              "chromium",
              "firefox"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/core/**/*.ts",
              "projects/core/**/*.html"
            ],
            "eslintConfig": "./eslint.config.mjs"
          }
        }
      }
    },
    "dummy": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/dummy",
      "sourceRoot": "projects/dummy/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/dummy",
            "index": "projects/dummy/src/index.html",
            "browser": "projects/dummy/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/dummy/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/dummy/public"
              }
            ],
            "styles": [
              "projects/dummy/src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "dummy:build:production"
            },
            "development": {
              "buildTarget": "dummy:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "browsers": [
              "chromium",
              "firefox"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/dummy/**/*.ts",
              "projects/dummy/**/*.html"
            ],
            "eslintConfig": "projects/dummy/eslint.config.mjs"
          }
        }
      }
    },
    "reactive-forms": {
      "projectType": "library",
      "root": "projects/reactive-forms",
      "sourceRoot": "projects/reactive-forms/src",
      "prefix": "ngxfb",
      "schematics": {
        "@schematics/angular:component": {
          "changeDetection": "OnPush"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/reactive-forms/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/reactive-forms/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/reactive-forms/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "browsers": [
              "chromium",
              "firefox"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/reactive-forms/**/*.ts",
              "projects/reactive-forms/**/*.html"
            ],
            "eslintConfig": "projects/reactive-forms/eslint.config.mjs"
          }
        }
      }
    },
    "docs": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "changeDetection": "OnPush"
        }
      },
      "root": "projects/docs",
      "sourceRoot": "projects/docs/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@ng-doc/builder:application",
          "options": {
            "browser": "projects/docs/src/main.ts",
            "tsConfig": "projects/docs/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "node_modules/@ng-doc/app/assets",
                "output": "assets/ng-doc/app"
              },
              {
                "glob": "**/*",
                "input": "node_modules/@ng-doc/ui-kit/assets",
                "output": "assets/ng-doc/ui-kit"
              },
              {
                "glob": "**/*",
                "input": "ng-doc/docs/assets",
                "output": "assets/ng-doc"
              },
              {
                "glob": "**/*",
                "input": "projects/docs/public"
              }
            ],
            "styles": [
              "node_modules/@ng-doc/app/styles/global.css",
              "node_modules/@ng-doc/app/styles/themes/dark.css",
              "projects/docs/src/styles.scss"
            ],
            "allowedCommonJsDependencies": [
              "@ng-doc/core",
              "dayjs",
              "dayjs/plugin/isoWeek.js",
              "dayjs/plugin/customParseFormat.js",
              "dayjs/plugin/advancedFormat.js",
              "elkjs/lib/elk.bundled.js",
              "@braintree/sanitize-url",
              "cytoscape-cose-bilkent"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "3MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@ng-doc/builder:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "docs:build:production"
            },
            "development": {
              "buildTarget": "docs:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/docs/**/*.ts",
              "projects/docs/**/*.html"
            ],
            "eslintConfig": "projects/docs/eslint.config.mjs"
          }
        }
      }
    },
    "setup": {
      "projectType": "library",
      "root": "projects/setup",
      "sourceRoot": "projects/setup",
      "architect": {
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/setup/**/*.ts"
            ],
            "eslintConfig": "./eslint.config.mjs"
          }
        }
      }
    },
    "schematics": {
      "projectType": "library",
      "root": "projects/schematics",
      "sourceRoot": "projects/schematics/schematics",
      "architect": {
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/schematics/**/*.ts",
              "projects/schematics/**/*.html"
            ],
            "eslintConfig": "projects/schematics/eslint.config.mjs"
          }
        }
      }
    }
  },
  "cli": {
    "schematicCollections": [
      "angular-eslint"
    ],
    "analytics": false
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}

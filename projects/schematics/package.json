{
  "name": "@ngx-formbar/schematics",
  "version": "0.0.1",
  "schematics": "./schematics/collection.json",
  "scripts": {
    "prebuild": "copyfiles -u 2 \"../setup/**/*.ts\" \"_setup/\"",
    "build": "tsc -p tsconfig.schematics.json",
    "postbuild": "copyfiles \"schematics/*/schema.json\" \"schematics/**/files/**/*\" \"schematics/collection.json\" \"../../dist/schematics/\""
  },
  "devDependencies": {
    "@angular-devkit/schematics": "file:../../node_modules/@angular-devkit/schematics",
    "@schematics/angular": "file:../../node_modules/@schematics/angular",
    "copyfiles": "file:../../node_modules/copyfiles",
    "typescript": "file:../../node_modules/typescript",
    "@angular-devkit/core": "file:../../node_modules/@angular-devkit/core",
    "@angular-devkit/architect": "file:../../node_modules/@angular-devkit/architect"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "keywords": [
    "angular",
    "typescript",
    "schematics",
    "ngx-formbar"
  ],
  "author": {
    "name": "Alexander Pahn",
    "email": "alexander.pahn@outlook.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheNordicOne/ngx-formbar.git"
  },
  "bugs": {
    "url": "https://github.com/TheNordicOne/ngx-formbar.issues"
  }
}

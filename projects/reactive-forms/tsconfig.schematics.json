{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": [
      "es2018",
      "dom"
    ],
    "declaration": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "rootDir": ".",
    "outDir": "../../dist/reactive-forms",
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strictNullChecks": true,
    "target": "es6",
    "types": [
      "node"
    ],
  },
  "include": [
    "schematics/**/*",
    "_setup/**/*"
  ],
  "exclude": [
    "schematics/*/files/**/*",
    "**/*.spec.ts",
    "schematics/tests/**/*"
  ]
}

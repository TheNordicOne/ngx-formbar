{
  "name": "@ngx-formbar/reactive-forms",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/reactive-forms/src",
  "prefix": "ngxfb",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": ["reactive-forms"],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/reactive-forms/ng-package.json",
        "tsConfig": "libs/reactive-forms/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/reactive-forms/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "build-schematics": {
      "dependsOn": ["build"],
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}/schematics"],
      "options": {
        "outputPath": "dist/libs/reactive-forms/schematics",
        "main": "libs/reactive-forms/schematics/ng-add/index.ts",
        "tsConfig": "libs/reactive-forms/tsconfig.schematics.json",
        "platform": "node",
        "format": ["cjs"],
        "bundle": true,
        "declaration": false,
        "generatePackageJson": false,
        "external": ["@angular-devkit/*", "@schematics/*", "typescript"],
        "assets": [
          {
            "input": "libs/reactive-forms/schematics",
            "glob": "collection.json",
            "output": "."
          },
          {
            "input": "libs/reactive-forms/schematics/ng-add",
            "glob": "schema.json",
            "output": "./ng-add"
          },
          {
            "input": "libs/reactive-forms/schematics/ng-add",
            "glob": "**/*.template",
            "output": "./ng-add"
          }
        ]
      }
    },
    "clean-schematics": {
      "dependsOn": ["build-schematics"],
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -f dist/{projectRoot}/schematics/package.json"
      }
    },
    "nx-release-publish": {
      "dependsOn": ["clean-schematics"],
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {}
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "libs/reactive-forms/.storybook",
        "browserTarget": "@ngx-formbar/reactive-forms:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/@ngx-formbar/reactive-forms",
        "configDir": "libs/reactive-forms/.storybook",
        "browserTarget": "@ngx-formbar/reactive-forms:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c libs/reactive-forms/.storybook --url=http://localhost:4400"
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": ["build-storybook"],
      "options": {
        "buildTarget": "@ngx-formbar/reactive-forms:build-storybook",
        "staticFilePath": "dist/storybook/@ngx-formbar/reactive-forms",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "@ngx-formbar/reactive-forms:build-storybook:ci"
        }
      }
    }
  }
}
